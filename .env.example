DEEPMAIL_ENV=production
DEEPMAIL__SERVER__HOST=0.0.0.0
DEEPMAIL__SERVER__PORT=3001
DEEPMAIL__SECURITY__JWT_SECRET=replace_me
DEEPMAIL__SECURITY__JWT_ISSUER=deepmail-inhouse
DEEPMAIL__SECURITY__JWT_AUDIENCE=deepmail-clients
DEEPMAIL__SECURITY__TOKEN_TTL_DAYS=7
DEEPMAIL__SECURITY__OTP_TTL_MINUTES=10
DEEPMAIL__SECURITY__OTP_MAX_ATTEMPTS=5
DEEPMAIL__SECURITY__OTP_LOCKOUT_SECS=900
DEEPMAIL__SECURITY__MTLS_REQUIRED_FOR_AUTH_ADMIN=true
DEEPMAIL__SECURITY__TRUSTED_CLIENT_CERT_FINGERPRINTS=[]
DEEPMAIL__SECURITY__ADMIN_IP_ALLOWLIST=[]
DEEPMAIL_JWT_SECRET_FILE=
DEEPMAIL_JWT_SECRET_CMD=
DEEPMAIL_ABUSEIPDB_API_KEY_FILE=
DEEPMAIL_ABUSEIPDB_API_KEY_CMD=
DEEPMAIL_VIRUSTOTAL_API_KEY_FILE=
DEEPMAIL_VIRUSTOTAL_API_KEY_CMD=
DEEPMAIL__REDIS__URL=redis://127.0.0.1:6379
DEEPMAIL__DATABASE__PATH=data/deepmail.db
DEEPMAIL__OBSERVABILITY__OTLP_ENABLED=true
DEEPMAIL__OBSERVABILITY__OTLP_ENDPOINT=http://127.0.0.1:4317
DEEPMAIL__BACKUP_PASSPHRASE=replace_me
DEEPMAIL_ABUSEIPDB_API_KEY=replace_me
DEEPMAIL_VIRUSTOTAL_API_KEY=replace_me
